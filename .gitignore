# Ignore the real secret files
.env
app/portfolio_targets.json
# Backup + staged-import artifacts (portfolio_targets.backup.json, .proposed.json)
app/portfolio_targets.*.json
app/portfolio.md

# Ignore Python caches
__pycache__/
*.pyc

# Ignore OpenClaw's auto-generated local hidden folder (if it's still lying around)
.openclaw/
openclaw_data/
# Ignore Mac system files
.DS_Store

# Ignore Claude Code local state (memory, image cache)
.claude/